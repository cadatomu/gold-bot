# ── IC Markets cTrader Open API ──────────────────────────────────────────────
# Obtén Client ID y Secret en el portal cTrader Open API
# Luego ejecuta: python scripts/get_ctrader_token.py

CTRADER_CLIENT_ID=tu_client_id_aqui
CTRADER_CLIENT_SECRET=tu_client_secret_aqui
CTRADER_ACCESS_TOKEN=         # generado por get_ctrader_token.py
CTRADER_REFRESH_TOKEN=        # generado por get_ctrader_token.py
CTRADER_ACCOUNT_ID=10027534   # cuenta demo IC Markets
CTRADER_DEMO=true             # true = demo | false = live (¡cuidado!)

# ── Interactive Brokers ───────────────────────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497              # 7497 = paper  |  4002 = live Gateway
IB_CLIENT_ID=1            # para scripts/backtest
IB_CLIENT_ID_BOT=5        # para el bot (distinto para evitar conflicto)
IB_ACCOUNT=               # DU... (paper) o U... (live)

# ── GoldBot ───────────────────────────────────────────────────────────────────
PAPER_MODE=true
RISK_PCT=0.08             # 8% risk por trade (resultado optimización)
INITIAL_EQUITY=10000      # capital inicial de referencia
CHECK_INTERVAL_MIN=15     # frecuencia del loop principal
STATE_FILE=/app/data/bot_state.json

# ── Telegram ──────────────────────────────────────────────────────────────────
# Crear bot en @BotFather → copiar token
# Obtener chat_id: hablarle al bot → api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=           # token de @BotFather
TELEGRAM_CHAT_ID=         # tu chat_id numérico

# ── Entorno ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
